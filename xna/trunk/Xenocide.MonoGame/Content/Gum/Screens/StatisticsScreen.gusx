  <Instance Name="ContainerInstance" BaseType="Container" />
  <Instance Name="BGImage" BaseType="Sprite" />
  <Instance Name="ButtonBar" BaseType="Container" />
  <Instance Name="ufoByRegionButton" BaseType="XenocideButton" />
  <Instance Name="ufoByCountryButton" BaseType="XenocideButton" />
  <Instance Name="xcomByRegionButton" BaseType="XenocideButton" />
  <Instance Name="xcomByCountryButton" BaseType="XenocideButton" />
  <Instance Name="fundsButton" BaseType="XenocideButton" />
  <Instance Name="geoscapeButton" BaseType="XenocideButton" />
  <Behaviors />
