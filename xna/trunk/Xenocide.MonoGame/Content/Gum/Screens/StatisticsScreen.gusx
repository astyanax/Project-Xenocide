    </Variable>
    <Variable Type="DimensionUnitType" Name="xcomByCountryButton.WidthUnits" SetsValue="true">
      <Value xsi:type="xsd:int">1</Value>
    </Variable>
    <Variable Type="string" Name="xcomByRegionButton.Parent" SetsValue="true">
      <Value xsi:type="xsd:string">ButtonBar</Value>
    </Variable>
    <Variable Type="string" Name="xcomByRegionButton.TextInstance.Text" SetsValue="true">
      <Value xsi:type="xsd:string">X-Corp by Region</Value>
    </Variable>
    <Variable Type="float" Name="xcomByRegionButton.Width" SetsValue="true">
      <Value xsi:type="xsd:float">100</Value>
    </Variable>
    <Variable Type="DimensionUnitType" Name="xcomByRegionButton.WidthUnits" SetsValue="true">
      <Value xsi:type="xsd:int">1</Value>
    </Variable>
