#----------------------------- Audio -----------------------------------------#
# All audio uses SoundEffectProcessor: OggImporter decodes OGG to PCM XNB.
# SongProcessor is unreliable on DesktopGL (produces 128-byte stubs).

#begin Content/Audio/Sounds/Menu/buttonclick1_ok.ogg
/importer:OggImporter
/processor:SoundEffectProcessor
