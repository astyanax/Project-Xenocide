#----------------------------- Global Properties ----------------------------#
/outputDir:bin/DesktopGL
/intermediateDir:obj/DesktopGL
/platform:DesktopGL
/config:
/profile:Reach
/compress:False

#----------------------------- Resources ------------------------------------#

