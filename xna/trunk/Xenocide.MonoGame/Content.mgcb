#----------------------------- Global Properties ----------------------------#
/outputDir:bin/DesktopGL
/intermediateDir:obj/DesktopGL
/platform:DesktopGL
/config:
/profile:Reach
/compress:False

#----------------------------- Resources ------------------------------------#

#begin Content/Shaders/GeoscapeShader.fx
/importer:EffectImporter
/processor:EffectProcessor
/processorParam:DebugMode=Auto
/build:Content/Shaders/GeoscapeShader.fx

#begin Content/Shaders/skybox.fx
/importer:EffectImporter
/processor:EffectProcessor
/processorParam:DebugMode=Auto
/build:Content/Shaders/skybox.fx

